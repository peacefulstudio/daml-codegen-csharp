set -euo pipefail

usage() {
  cat <<EOF
Usage: dpm-codegen-cs --dar <path-to-dar> --out <output-dir> [--publish-nuget --nuget-config <path> --nuget-source <name>] [--] [emitter-args...]

Runs the bundled JVM helper to decode the DAR into an Intermediate DAR proto,
then runs the bundled C# emitter to write .cs files. Any arguments after
'--' (or remaining after --dar/--out) are forwarded to the emitter.

Options:
  --publish-nuget          Pack and push generated NuGet package after emission.
                           Implies --generate-project. Requires --nuget-config and
                           --nuget-source. Pass --runtime-version in emitter args
                           to pin the Daml.Runtime dependency version.
  --nuget-config <path>    Path to NuGet.config (required when --publish-nuget is set).
  --nuget-source <name>    Source name in NuGet.config to push to (required when
                           --publish-nuget is set).
EOF
}

BUNDLE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HELPER_JAR="${BUNDLE_ROOT}/bin/daml-codegen-jvm-helper.jar"
EMITTER="${BUNDLE_ROOT}/bin/Daml.Codegen.CSharp.Cli"

DAR=""
OUT=""
PUBLISH_NUGET=""
NUGET_CONFIG=""
NUGET_SOURCE=""
EMITTER_ARGS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dar) DAR="$2"; shift 2 ;;
    --out) OUT="$2"; shift 2 ;;
    --publish-nuget) PUBLISH_NUGET="1"; shift 1 ;;
    --nuget-config) NUGET_CONFIG="$2"; shift 2 ;;
    --nuget-source) NUGET_SOURCE="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    --) shift; EMITTER_ARGS+=("$@"); break ;;
    *) EMITTER_ARGS+=("$1"); shift ;;
  esac
done

if [[ -z "${DAR}" || -z "${OUT}" ]]; then
  usage >&2
  exit 2
fi

if [[ -n "${PUBLISH_NUGET}" && -z "${NUGET_CONFIG}" ]]; then
  echo "dpm-codegen-cs: --nuget-config is required when --publish-nuget is set" >&2
  usage >&2
  exit 2
fi
if [[ -n "${PUBLISH_NUGET}" && -z "${NUGET_SOURCE}" ]]; then
  echo "dpm-codegen-cs: --nuget-source is required when --publish-nuget is set" >&2
  usage >&2
  exit 2
fi
if [[ -n "${PUBLISH_NUGET}" ]] && ! command -v dotnet >/dev/null 2>&1; then
  echo "dpm-codegen-cs: 'dotnet' not found on PATH (.NET SDK required for --publish-nuget)" >&2
  exit 1
fi

if [[ ! -f "${DAR}" ]]; then
  echo "dpm-codegen-cs: DAR not found: ${DAR}" >&2
  exit 1
fi
if [[ ! -f "${HELPER_JAR}" ]]; then
  echo "dpm-codegen-cs: bundled JVM helper missing: ${HELPER_JAR}" >&2
  exit 1
fi
if [[ ! -x "${EMITTER}" ]]; then
  echo "dpm-codegen-cs: bundled emitter missing or not executable: ${EMITTER}" >&2
  exit 1
fi
if ! command -v java >/dev/null 2>&1; then
  echo "dpm-codegen-cs: 'java' not found on PATH (dpm install precondition: JDK 17+)" >&2
  exit 1
fi

if [[ -n "${PUBLISH_NUGET}" ]]; then
  if ! printf '%s\0' "${EMITTER_ARGS[@]}" | grep -qz -- '--generate-project'; then
    EMITTER_ARGS+=("--generate-project")
  fi
  if [[ ! " ${EMITTER_ARGS[*]} " =~ [[:space:]]--runtime-version([[:space:]]|=) ]]; then
    echo "dpm-codegen-cs: warning: --runtime-version not set; generated .csproj will reference Daml.Runtime with wildcard version (*)" >&2
  fi
fi

mkdir -p "${OUT}"
TMP="$(mktemp -d)"
trap 'rm -rf "${TMP}"' EXIT
INTERMEDIATE="${TMP}/intermediate.binpb"

java -jar "${HELPER_JAR}" --dar "${DAR}" --out "${INTERMEDIATE}"
"${EMITTER}" --intermediate "${INTERMEDIATE}" -o "${OUT}" ${EMITTER_ARGS[@]+"${EMITTER_ARGS[@]}"}

if [[ -n "${PUBLISH_NUGET}" ]]; then
  dotnet pack "${OUT}" -c Release
  mapfile -t nupkgs < <(find "${OUT}/bin/Release" -maxdepth 1 -name '*.nupkg' -not -name '*.symbols.nupkg')
  [[ ${#nupkgs[@]} -gt 0 ]] || { echo "dpm-codegen-cs: no .nupkg produced" >&2; exit 1; }
  [[ ${#nupkgs[@]} -eq 1 ]] || { echo "dpm-codegen-cs: multiple .nupkg files found under ${OUT}/bin/Release; refusing to guess which to push" >&2; exit 1; }
  dotnet nuget push "${nupkgs[0]}" --configfile "${NUGET_CONFIG}" \
    --source "${NUGET_SOURCE}" --skip-duplicate
fi
